    "    \"\\n\",\n",
    "    \"elapsed = time.time() - t0\\n\",\n",
    "    \"print(f'\\\\nDone! {len(tile_results)} tiles optimized in {elapsed:.1f}s')\"\n",
    "   ]\n",
    "  },\n",
