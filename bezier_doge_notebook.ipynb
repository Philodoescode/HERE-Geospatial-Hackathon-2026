    "   },\n",
    "   \"source\": [\n",
    "    \"import ast, json, os, time, warnings\\n\",\n",
    "    \"from dataclasses import dataclass, field\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"from typing import Dict, List, Optional, Tuple\\n\",\n",
    "    \"\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import matplotlib\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import torch\\n\",\n",
    "    \"import torch.nn as nn\\n\",\n",
    "    \"import torch.nn.functional as F\\n\",\n",
    "    \"\\n\",\n",
    "    \"from pyproj import CRS, Transformer\\n\",\n",
    "    \"from scipy.ndimage import gaussian_filter, label as nd_label, maximum_filter\\n\",\n",
    "    \"from scipy.spatial import cKDTree\\n\",\n",
    "    \"from shapely import wkt\\n\",\n",
    "    \"from shapely.geometry import LineString, MultiLineString, box\\n\",\n",
    "    \"from shapely.ops import linemerge, transform\\n\",\n",
