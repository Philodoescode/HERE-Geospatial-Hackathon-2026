    "    \"    DATA_DIR / \\\"Kosovo's nav streets\\\" / 'nav_kosovo.parquet',\\n\",\n",
    "    \"    DATA_DIR / \\\"Kosovo's nav streets\\\" / 'nav_kosovo.csv',\\n\",\n",
    "    \"    DATA_DIR / 'nav_kosovo.parquet',\\n\",\n",
    "    \"    DATA_DIR / 'nav_kosovo.csv',\\n\",\n",
    "    \"]\\n\",\n",
    "    \"gt_path = next((p for p in gt_candidates if p.exists()), None)\\n\",\n",
    "    \"\\n\",\n",
    "    \"if gt_path and geometries:\\n\",\n",
    "    \"    print(f'Ground truth found: {gt_path}')\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Load ground truth\\n\",\n",
    "    \"    gt_df = pd.read_parquet(gt_path) if gt_path.suffix == '.parquet' else pd.read_csv(gt_path)\\n\",\n",
    "    \"    gt_geoms = []\\n\",\n",
    "    \"    for s in gt_df['geom'].astype(str):\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            g = wkt.loads(s)\\n\",\n",
    "    \"            if g and not g.is_empty:\\n\",\n",
    "    \"                gt_geoms.append(g)\\n\",\n",
    "    \"        except: pass\\n\",\n",
    "    \"\\n\",\n",
    "    \"    gt_gdf = gpd.GeoDataFrame({'id': range(len(gt_geoms))}, geometry=gt_geoms, crs='EPSG:4326')\\n\",\n",
    "    \"    gen_gdf = gdf\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Project both to UTM for metric computation\\n\",\n",
    "    \"    gt_proj = gt_gdf.to_crs(f'EPSG:{UTM_EPSG}')\\n\",\n",
    "    \"    gen_proj = gen_gdf.to_crs(f'EPSG:{UTM_EPSG}')\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Length-based precision/recall (15m buffer)\\n\",\n",
    "    \"    from shapely.ops import unary_union\\n\",\n",
    "    \"    BUFFER_M = 15.0\\n\",\n",
    "    \"    gt_buf = unary_union(gt_proj.buffer(BUFFER_M).tolist())\\n\",\n",
    "    \"    gen_buf = unary_union(gen_proj.buffer(BUFFER_M).tolist())\\n\",\n",
    "    \"\\n\",\n",
    "    \"    gen_len = float(gen_proj.length.sum())\\n\",\n",
    "    \"    gt_len = float(gt_proj.length.sum())\\n\",\n",
    "    \"    matched_gen = float(gen_proj.geometry.intersection(gt_buf).length.sum())\\n\",\n",
    "    \"    matched_gt = float(gt_proj.geometry.intersection(gen_buf).length.sum())\\n\",\n",
    "    \"\\n\",\n",
    "    \"    precision = matched_gen / gen_len if gen_len > 0 else 0\\n\",\n",
    "    \"    recall = matched_gt / gt_len if gt_len > 0 else 0\\n\",\n",
    "    \"    f1 = 2*precision*recall/(precision+recall) if (precision+recall) > 0 else 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(f'\\\\n=== Evaluation Results ===')\\n\",\n",
    "    \"    print(f'Generated: {len(gen_proj)} segments, {gen_len:.0f}m total')\\n\",\n",
    "    \"    print(f'Ground truth: {len(gt_proj)} segments, {gt_len:.0f}m total')\\n\",\n",
    "    \"    print(f'Precision: {precision:.4f}')\\n\",\n",
    "    \"    print(f'Recall:    {recall:.4f}')\\n\",\n",
    "    \"    print(f'F1:        {f1:.4f}')\\n\",\n",
    "    \"\\n\",\n",
    "    \"    metrics = {'precision': precision, 'recall': recall, 'f1': f1,\\n\",\n",
    "    \"               'gen_length_m': gen_len, 'gt_length_m': gt_len,\\n\",\n",
    "    \"               'gen_count': len(gen_proj), 'gt_count': len(gt_proj)}\\n\",\n",
    "    \"    with open(OUTPUT_DIR / 'metrics.json', 'w') as f:\\n\",\n",
    "    \"        json.dump(metrics, f, indent=2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Overlay plot\\n\",\n",
    "    \"    fig, ax = plt.subplots(figsize=(12, 12))\\n\",\n",
    "    \"    gt_gdf.plot(ax=ax, linewidth=1.0, color='#1f77b4', alpha=0.6, label='Ground Truth')\\n\",\n",
    "    \"    gen_gdf.plot(ax=ax, linewidth=1.0, color='#d62728', alpha=0.6, label='Bezier DOGE')\\n\",\n",
    "    \"    ax.set_title(f'Centerline Comparison (P={precision:.3f} R={recall:.3f} F1={f1:.3f})')\\n\",\n",
    "    \"    ax.legend(loc='lower left')\\n\",\n",
    "    \"    ax.set_axis_off()\\n\",\n",
    "    \"    plt.savefig(OUTPUT_DIR / 'gt_comparison.png', dpi=150, bbox_inches='tight')\\n\",\n",
    "    \"    plt.show()\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    print('Ground truth not found or no geometries generated. Skipping evaluation.')\"\n",
    "   ]\n",
