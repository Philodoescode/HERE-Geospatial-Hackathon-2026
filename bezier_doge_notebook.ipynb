    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Convert tile-local pixel coords to global UTM coords\\n\",\n",
    "    \"all_polylines_utm = []\\n\",\n",
    "    \"for tile, graph in tile_results:\\n\",\n",
    "    \"    if graph.n_edges == 0: continue\\n\",\n",
    "    \"    for poly_px in graph.to_polylines(samples=50):\\n\",\n",
    "    \"        utm_x = tile.origin_utm_x + poly_px[:, 0] * RESOLUTION_M\\n\",\n",
    "    \"        utm_y = tile.origin_utm_y - poly_px[:, 1] * RESOLUTION_M\\n\",\n",
    "    \"        all_polylines_utm.append(np.column_stack([utm_x, utm_y]))\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f'Total polylines before stitching: {len(all_polylines_utm)}')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Merge boundary endpoints\\n\",\n",
    "    \"STITCH_DIST = 4.0\\n\",\n",
    "    \"if len(all_polylines_utm) > 1:\\n\",\n",
    "    \"    endpoints = []\\n\",\n",
    "    \"    for i, p in enumerate(all_polylines_utm):\\n\",\n",
    "    \"        endpoints.append((i, 0, p[0]))\\n\",\n",
    "    \"        endpoints.append((i, -1, p[-1]))\\n\",\n",
    "    \"    ep_coords = np.array([e[2] for e in endpoints])\\n\",\n",
    "    \"    tree = cKDTree(ep_coords)\\n\",\n",
    "    \"    for i, j in tree.query_pairs(r=STITCH_DIST):\\n\",\n",
    "    \"        pi, pp, pc = endpoints[i]; pj, jp, jc = endpoints[j]\\n\",\n",
    "    \"        if pi == pj: continue\\n\",\n",
    "    \"        mid = (pc + jc) / 2\\n\",\n",
    "    \"        all_polylines_utm[pi][pp] = mid\\n\",\n",
    "    \"        all_polylines_utm[pj][jp] = mid\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f'Total polylines after stitching: {len(all_polylines_utm)}')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Convert to WGS84 and save\\n\",\n",
    "    \"import geopandas as gpd\\n\",\n",
