    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 2. Rasterize Traces into Segmentation Mask\\n\",\n",
    "    \"\\n\",\n",
    "    \"This is the key adaptation: instead of SAM2 segmentation of satellite imagery,\\n\",\n",
    "    \"we rasterize GPS traces into a density heatmap that serves as our target mask `S`.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Rasterization config\\n\",\n",
    "    \"VPD_BUFFER_M = 3.0\\n\",\n",
    "    \"HPD_BUFFER_M = 5.0\\n\",\n",
    "    \"VPD_WEIGHT = 2.0\\n\",\n",
    "    \"HPD_WEIGHT = 1.0\\n\",\n",
    "    \"GAUSSIAN_SIGMA = 2.0\\n\",\n",
    "    \"MASK_THRESHOLD = 0.3\\n\",\n",
    "    \"PADDING_M = 50.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Build raster bounds\\n\",\n",
    "    \"minx = utm_bounds[0] - PADDING_M\\n\",\n",
    "    \"miny = utm_bounds[1] - PADDING_M\\n\",\n",
    "    \"maxx = utm_bounds[2] + PADDING_M\\n\",\n",
    "    \"maxy = utm_bounds[3] + PADDING_M\\n\",\n",
    "    \"W_px = int(np.ceil((maxx - minx) / RESOLUTION_M))\\n\",\n",
    "    \"H_px = int(np.ceil((maxy - miny) / RESOLUTION_M))\\n\",\n",
    "    \"print(f'Raster size: {W_px} x {H_px} pixels ({maxx-minx:.0f} x {maxy-miny:.0f} m)')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Rasterize\\n\",\n",
    "    \"density = np.zeros((H_px, W_px), dtype=np.float64)\\n\",\n",
    "    \"\\n\",\n",
    "    \"for line, source in zip(lines_utm, sources):\\n\",\n",
    "    \"    buffer_m = VPD_BUFFER_M if source == 'VPD' else HPD_BUFFER_M\\n\",\n",
    "    \"    weight = VPD_WEIGHT if source == 'VPD' else HPD_WEIGHT\\n\",\n",
    "    \"\\n\",\n",
    "    \"    total_len = line.length\\n\",\n",
    "    \"    step = RESOLUTION_M * 0.5\\n\",\n",
    "    \"    n_samples = max(int(total_len / step), 2)\\n\",\n",
    "    \"    fracs = np.linspace(0.0, 1.0, n_samples)\\n\",\n",
    "    \"    pts = np.array([(line.interpolate(f, normalized=True).x,\\n\",\n",
    "    \"                     line.interpolate(f, normalized=True).y) for f in fracs])\\n\",\n",
    "    \"    px = ((pts[:, 0] - minx) / RESOLUTION_M).astype(np.int32)\\n\",\n",
    "    \"    py = ((maxy - pts[:, 1]) / RESOLUTION_M).astype(np.int32)\\n\",\n",
    "    \"    valid = (px >= 0) & (px < W_px) & (py >= 0) & (py < H_px)\\n\",\n",
    "    \"    np.add.at(density, (py[valid], px[valid]), weight)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Dilate to approximate line buffering\\n\",\n",
    "    \"avg_buffer_px = max(1, int(np.mean([VPD_BUFFER_M, HPD_BUFFER_M]) / RESOLUTION_M))\\n\",\n",
    "    \"density = maximum_filter(density, size=2 * avg_buffer_px + 1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Normalize + smooth\\n\",\n",
    "    \"if density.max() > 0:\\n\",\n",
    "    \"    density /= density.max()\\n\",\n",
    "    \"density = gaussian_filter(density, sigma=GAUSSIAN_SIGMA)\\n\",\n",
    "    \"if density.max() > 0:\\n\",\n",
    "    \"    density /= density.max()\\n\",\n",
    "    \"\\n\",\n",
    "    \"soft_mask = density.astype(np.float32)\\n\",\n",
    "    \"binary_mask = (soft_mask >= MASK_THRESHOLD).astype(np.float32)\\n\",\n",
    "    \"RASTER_ORIGIN = (minx, maxy)  # top-left in UTM\\n\",\n",
    "    \"\\n\",\n",
    "    \"coverage = binary_mask.sum() / binary_mask.size * 100\\n\",\n",
    "    \"print(f'Mask coverage: {coverage:.1f}%')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Visualize\\n\",\n",
    "    \"fig, axes = plt.subplots(1, 2, figsize=(18, 8))\\n\",\n",
    "    \"axes[0].imshow(soft_mask, cmap='hot', origin='upper')\\n\",\n",
    "    \"axes[0].set_title('Soft Density Mask (target S)')\\n\",\n",
    "    \"axes[1].imshow(binary_mask, cmap='gray', origin='upper')\\n\",\n",
    "    \"axes[1].set_title(f'Binary Mask (threshold={MASK_THRESHOLD})')\\n\",\n",
    "    \"for ax in axes:\\n\",\n",
    "    \"    ax.set_axis_off()\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.savefig(OUTPUT_DIR / 'raster_mask.png', dpi=150, bbox_inches='tight')\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 3. Tiling\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"TILE_SIZE = 512\\n\",\n",
    "    \"TILE_OVERLAP = 64\\n\",\n",
    "    \"MIN_TILE_COVERAGE = 0.02\\n\",\n",
    "    \"\\n\",\n",
    "    \"@dataclass\\n\",\n",
    "    \"class Tile:\\n\",\n",
    "    \"    row: int; col: int\\n\",\n",
    "    \"    y_start: int; y_end: int; x_start: int; x_end: int\\n\",\n",
    "    \"    soft_mask: np.ndarray = None\\n\",\n",
    "    \"    coverage: float = 0.0\\n\",\n",
    "    \"    origin_utm_x: float = 0.0\\n\",\n",
    "    \"    origin_utm_y: float = 0.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"step = TILE_SIZE - 2 * TILE_OVERLAP\\n\",\n",
    "    \"n_rows = max(1, int(np.ceil((H_px - TILE_OVERLAP) / step)))\\n\",\n",
    "    \"n_cols = max(1, int(np.ceil((W_px - TILE_OVERLAP) / step)))\\n\",\n",
    "    \"\\n\",\n",
    "    \"tiles = []\\n\",\n",
    "    \"for r in range(n_rows):\\n\",\n",
    "    \"    for c in range(n_cols):\\n\",\n",
    "    \"        y0 = r * step\\n\",\n",
    "    \"        x0 = c * step\\n\",\n",
    "    \"        y1 = min(y0 + TILE_SIZE, H_px)\\n\",\n",
    "    \"        x1 = min(x0 + TILE_SIZE, W_px)\\n\",\n",
    "    \"        if y1 - y0 < 64 or x1 - x0 < 64:\\n\",\n",
    "    \"            continue\\n\",\n",
    "    \"        tile_bin = binary_mask[y0:y1, x0:x1]\\n\",\n",
    "    \"        cov = tile_bin.sum() / tile_bin.size\\n\",\n",
    "    \"        if cov >= MIN_TILE_COVERAGE:\\n\",\n",
    "    \"            tiles.append(Tile(\\n\",\n",
    "    \"                row=r, col=c, y_start=y0, y_end=y1, x_start=x0, x_end=x1,\\n\",\n",
    "    \"                soft_mask=soft_mask[y0:y1, x0:x1].copy(),\\n\",\n",
    "    \"                coverage=cov,\\n\",\n",
    "    \"                origin_utm_x=RASTER_ORIGIN[0] + x0 * RESOLUTION_M,\\n\",\n",
    "    \"                origin_utm_y=RASTER_ORIGIN[1] - y0 * RESOLUTION_M,\\n\",\n",
    "    \"            ))\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f'Tile grid: {n_rows} x {n_cols} = {n_rows*n_cols} total, {len(tiles)} non-empty')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 4. Bezier Graph Data Structure\\n\",\n",
    "    \"\\n\",\n",
    "    \"The core representation from the DOGE paper (Section 3.1).\\n\",\n",
    "    \"Each edge is a cubic Bezier curve with 4 control points,\\n\",\n",
    "    \"reparameterized via alpha (chord projection) and d (perpendicular offset).\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"class BezierGraph(nn.Module):\\n\",\n",
    "    \"    \\\"\\\"\\\"Parametric road network graph using cubic Bezier curves.\\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __init__(self, canvas_h, canvas_w):\\n\",\n",
    "    \"        super().__init__()\\n\",\n",
    "    \"        self.canvas_h = canvas_h\\n\",\n",
    "    \"        self.canvas_w = canvas_w\\n\",\n",
    "    \"        self.node_positions = nn.Parameter(torch.zeros(0, 2))\\n\",\n",
    "    \"        self.register_buffer('edge_indices', torch.zeros(0, 2, dtype=torch.long))\\n\",\n",
    "    \"        self.edge_alpha = nn.Parameter(torch.zeros(0, 2))\\n\",\n",
    "    \"        self.edge_offset = nn.Parameter(torch.zeros(0, 2))\\n\",\n",
    "    \"        self.edge_width = nn.Parameter(torch.zeros(0))\\n\",\n",
    "    \"        self._n_nodes = 0\\n\",\n",
    "    \"        self._n_edges = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    @property\\n\",\n",
    "    \"    def n_nodes(self): return self._n_nodes\\n\",\n",
    "    \"    @property\\n\",\n",
    "    \"    def n_edges(self): return self._n_edges\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def add_nodes(self, positions):\\n\",\n",
    "    \"        K = positions.shape[0]\\n\",\n",
    "    \"        start = self._n_nodes\\n\",\n",
    "    \"        if self._n_nodes == 0:\\n\",\n",
    "    \"            self.node_positions = nn.Parameter(positions.clone().float())\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            self.node_positions = nn.Parameter(\\n\",\n",
    "    \"                torch.cat([self.node_positions.data, positions.float()], 0))\\n\",\n",
    "    \"        self._n_nodes += K\\n\",\n",
    "    \"        return torch.arange(start, start + K, device=positions.device)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def add_edges(self, start_nodes, end_nodes, alphas=None, offsets=None, widths=None):\\n\",\n",
    "    \"        K = start_nodes.shape[0]\\n\",\n",
    "    \"        dev = start_nodes.device\\n\",\n",
    "    \"        if alphas is None:\\n\",\n",
    "    \"            alphas = torch.zeros(K, 2, device=dev)\\n\",\n",
    "    \"            alphas[:, 0] = 1/3; alphas[:, 1] = 2/3\\n\",\n",
    "    \"        if offsets is None:\\n\",\n",
    "    \"            offsets = torch.zeros(K, 2, device=dev)\\n\",\n",
    "    \"        if widths is None:\\n\",\n",
    "    \"            widths = torch.full((K,), 3.0, device=dev)\\n\",\n",
    "    \"        new_idx = torch.stack([start_nodes.long(), end_nodes.long()], 1)\\n\",\n",
    "    \"        if self._n_edges == 0:\\n\",\n",
    "    \"            self.edge_indices = new_idx\\n\",\n",
    "    \"            self.edge_alpha = nn.Parameter(alphas.clone().float())\\n\",\n",
    "    \"            self.edge_offset = nn.Parameter(offsets.clone().float())\\n\",\n",
    "    \"            self.edge_width = nn.Parameter(widths.clone().float())\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            self.edge_indices = torch.cat([self.edge_indices, new_idx], 0)\\n\",\n",
    "    \"            self.edge_alpha = nn.Parameter(torch.cat([self.edge_alpha.data, alphas.float()], 0))\\n\",\n",
    "    \"            self.edge_offset = nn.Parameter(torch.cat([self.edge_offset.data, offsets.float()], 0))\\n\",\n",
    "    \"            self.edge_width = nn.Parameter(torch.cat([self.edge_width.data, widths.float()], 0))\\n\",\n",
    "    \"        self._n_edges += K\\n\",\n",
    "    \"        return torch.arange(self._n_edges - K, self._n_edges, device=dev)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def compute_control_points(self, edge_idx=None):\\n\",\n",
    "    \"        \\\"\\\"\\\"Eq 2a-2d: compute P0, P1, P2, P3 for each edge.\\\"\\\"\\\"\\n\",\n",
    "    \"        if edge_idx is None:\\n\",\n",
    "    \"            edge_idx = torch.arange(self._n_edges, device=self.node_positions.device)\\n\",\n",
    "    \"        if len(edge_idx) == 0:\\n\",\n",
    "    \"            return torch.zeros(0, 4, 2, device=self.node_positions.device)\\n\",\n",
    "    \"        idx = self.edge_indices[edge_idx]\\n\",\n",
    "    \"        P0 = self.node_positions[idx[:, 0]]\\n\",\n",
    "    \"        P3 = self.node_positions[idx[:, 1]]\\n\",\n",
    "    \"        alpha = torch.clamp(self.edge_alpha[edge_idx], 0, 1)\\n\",\n",
    "    \"        offset = self.edge_offset[edge_idx]\\n\",\n",
    "    \"        chord = P3 - P0\\n\",\n",
    "    \"        chord_len = torch.norm(chord, dim=1, keepdim=True).clamp(min=1e-6)\\n\",\n",
    "    \"        chord_dir = chord / chord_len\\n\",\n",
    "    \"        normal = torch.stack([-chord_dir[:, 1], chord_dir[:, 0]], dim=1)\\n\",\n",
    "    \"        P1 = (1 - alpha[:, 0:1]) * P0 + alpha[:, 0:1] * P3 + offset[:, 0:1] * normal\\n\",\n",
    "    \"        P2 = (1 - alpha[:, 1:2]) * P0 + alpha[:, 1:2] * P3 + offset[:, 1:2] * normal\\n\",\n",
    "    \"        return torch.stack([P0, P1, P2, P3], dim=1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def sample_curves(self, n_samples=50, edge_idx=None):\\n\",\n",
    "    \"        \\\"\\\"\\\"Eq 1: evaluate cubic Bezier at uniform t values.\\\"\\\"\\\"\\n\",\n",
    "    \"        cp = self.compute_control_points(edge_idx)\\n\",\n",
    "    \"        if cp.shape[0] == 0:\\n\",\n",
    "    \"            return torch.zeros(0, n_samples, 2, device=cp.device)\\n\",\n",
    "    \"        t = torch.linspace(0, 1, n_samples, device=cp.device).unsqueeze(0).unsqueeze(-1)\\n\",\n",
    "    \"        P0, P1, P2, P3 = cp[:, 0:1], cp[:, 1:2], cp[:, 2:3], cp[:, 3:4]\\n\",\n",
    "    \"        omt = 1.0 - t\\n\",\n",
    "    \"        return omt**3*P0 + 3*omt**2*t*P1 + 3*omt*t**2*P2 + t**3*P3\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def get_edge_tangents(self, edge_idx=None):\\n\",\n",
    "    \"        cp = self.compute_control_points(edge_idx)\\n\",\n",
    "    \"        if cp.shape[0] == 0:\\n\",\n",
    "    \"            e = torch.zeros(0, 2, device=cp.device)\\n\",\n",
    "    \"            return e, e\\n\",\n",
    "    \"        return 3*(cp[:,1]-cp[:,0]), 3*(cp[:,3]-cp[:,2])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def node_degree(self):\\n\",\n",
    "    \"        deg = torch.zeros(self._n_nodes, dtype=torch.long, device=self.node_positions.device)\\n\",\n",
    "    \"        if self._n_edges > 0:\\n\",\n",
    "    \"            for i in range(2):\\n\",\n",
    "    \"                deg.scatter_add_(0, self.edge_indices[:, i],\\n\",\n",
    "    \"                                 torch.ones(self._n_edges, dtype=torch.long, device=deg.device))\\n\",\n",
    "    \"        return deg\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def edges_at_node(self, node_idx):\\n\",\n",
    "    \"        result = []\\n\",\n",
    "    \"        for e in range(self._n_edges):\\n\",\n",
    "    \"            if self.edge_indices[e, 0].item() == node_idx: result.append((e, True))\\n\",\n",
    "    \"            if self.edge_indices[e, 1].item() == node_idx: result.append((e, False))\\n\",\n",
    "    \"        return result\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def remove_edges(self, mask):\\n\",\n",
    "    \"        keep = ~mask\\n\",\n",
    "    \"        if keep.all(): return\\n\",\n",
    "    \"        self.edge_indices = self.edge_indices[keep]\\n\",\n",
    "    \"        self.edge_alpha = nn.Parameter(self.edge_alpha.data[keep])\\n\",\n",
    "    \"        self.edge_offset = nn.Parameter(self.edge_offset.data[keep])\\n\",\n",
    "    \"        self.edge_width = nn.Parameter(self.edge_width.data[keep])\\n\",\n",
    "    \"        self._n_edges = int(keep.sum().item())\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def remove_isolated_nodes(self):\\n\",\n",
    "    \"        if self._n_nodes == 0: return\\n\",\n",
    "    \"        deg = self.node_degree()\\n\",\n",
    "    \"        keep = deg > 0\\n\",\n",
    "    \"        if keep.all(): return\\n\",\n",
    "    \"        new_idx = torch.full((self._n_nodes,), -1, dtype=torch.long, device=keep.device)\\n\",\n",
    "    \"        new_idx[keep] = torch.arange(keep.sum().item(), device=keep.device)\\n\",\n",
    "    \"        self.node_positions = nn.Parameter(self.node_positions.data[keep])\\n\",\n",
    "    \"        self._n_nodes = int(keep.sum().item())\\n\",\n",
    "    \"        if self._n_edges > 0:\\n\",\n",
    "    \"            self.edge_indices = new_idx[self.edge_indices]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def to_polylines(self, samples=50):\\n\",\n",
    "    \"        with torch.no_grad():\\n\",\n",
    "    \"            if self._n_edges == 0: return []\\n\",\n",
    "    \"            pts = self.sample_curves(n_samples=samples)\\n\",\n",
    "    \"            return [pts[e].cpu().numpy() for e in range(pts.shape[0])]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def get_optimizable_params(self):\\n\",\n",
    "    \"        return [self.node_positions, self.edge_alpha, self.edge_offset, self.edge_width]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __repr__(self):\\n\",\n",
    "    \"        return f'BezierGraph(nodes={self._n_nodes}, edges={self._n_edges}, canvas={self.canvas_h}x{self.canvas_w})'\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 5. Differentiable Renderer\\n\",\n",
    "    \"\\n\",\n",
    "    \"Soft Gaussian renderer in pure PyTorch: sample points along each Bezier curve,\\n\",\n",
    "    \"apply a Gaussian kernel to compute each pixel's coverage. Fully differentiable.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"def render_graph(graph, canvas_h=None, canvas_w=None, n_samples=64):\\n\",\n",
    "    \"    \\\"\\\"\\\"Differentiable soft rendering of a BezierGraph.\\\"\\\"\\\"\\n\",\n",
    "    \"    H = canvas_h or graph.canvas_h\\n\",\n",
    "    \"    W = canvas_w or graph.canvas_w\\n\",\n",
    "    \"    dev = graph.node_positions.device\\n\",\n",
    "    \"    if graph.n_edges == 0:\\n\",\n",
    "    \"        return torch.zeros(H, W, device=dev)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    curve_pts = graph.sample_curves(n_samples=n_samples)  # (E, T, 2)\\n\",\n",
    "    \"    widths = torch.abs(graph.edge_width).clamp(min=0.5)\\n\",\n",
    "    \"    canvas = torch.zeros(H, W, device=dev)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for b in range(curve_pts.shape[0]):\\n\",\n",
    "    \"        pts = curve_pts[b]  # (T, 2)\\n\",\n",
    "    \"        sig = widths[b]\\n\",\n",
    "    \"        pad = sig * 3\\n\",\n",
    "    \"        x_min = max(0, int(pts[:, 0].min().item() - pad.item()))\\n\",\n",
    "    \"        x_max = min(W, int(pts[:, 0].max().item() + pad.item()) + 1)\\n\",\n",
    "    \"        y_min = max(0, int(pts[:, 1].min().item() - pad.item()))\\n\",\n",
    "    \"        y_max = min(H, int(pts[:, 1].max().item() + pad.item()) + 1)\\n\",\n",
    "    \"        if x_max <= x_min or y_max <= y_min:\\n\",\n",
    "    \"            continue\\n\",\n",
    "    \"        gy, gx = torch.meshgrid(\\n\",\n",
    "    \"            torch.arange(y_min, y_max, device=dev, dtype=torch.float32),\\n\",\n",
    "    \"            torch.arange(x_min, x_max, device=dev, dtype=torch.float32),\\n\",\n",
    "    \"            indexing='ij')\\n\",\n",
    "    \"        pixels = torch.stack([gx, gy], -1).reshape(-1, 1, 2)  # (P, 1, 2)\\n\",\n",
    "    \"        dist_sq = ((pixels - pts.unsqueeze(0))**2).sum(-1).min(1).values  # (P,)\\n\",\n",
    "    \"        contribution = torch.exp(-dist_sq / (2 * sig * sig))\\n\",\n",
    "    \"        canvas[y_min:y_max, x_min:x_max] = torch.max(\\n\",\n",
    "    \"            canvas[y_min:y_max, x_min:x_max], contribution.reshape(y_max-y_min, x_max-x_min))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return canvas.clamp(0, 1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def render_single_edge(graph, edge_idx, H, W, n_samples=64):\\n\",\n",
    "    \"    \\\"\\\"\\\"Render a single edge for overlap computation.\\\"\\\"\\\"\\n\",\n",
    "    \"    dev = graph.node_positions.device\\n\",\n",
    "    \"    idx = torch.tensor([edge_idx], device=dev)\\n\",\n",
    "    \"    pts = graph.sample_curves(n_samples=n_samples, edge_idx=idx)[0]\\n\",\n",
    "    \"    sig = torch.abs(graph.edge_width[edge_idx]).clamp(min=0.5)\\n\",\n",
    "    \"    canvas = torch.zeros(H, W, device=dev)\\n\",\n",
    "    \"    pad = sig * 3\\n\",\n",
    "    \"    x_min = max(0, int(pts[:, 0].min().item() - pad.item()))\\n\",\n",
    "    \"    x_max = min(W, int(pts[:, 0].max().item() + pad.item()) + 1)\\n\",\n",
    "    \"    y_min = max(0, int(pts[:, 1].min().item() - pad.item()))\\n\",\n",
    "    \"    y_max = min(H, int(pts[:, 1].max().item() + pad.item()) + 1)\\n\",\n",
    "    \"    if x_max <= x_min or y_max <= y_min:\\n\",\n",
    "    \"        return canvas\\n\",\n",
    "    \"    gy, gx = torch.meshgrid(\\n\",\n",
    "    \"        torch.arange(y_min, y_max, device=dev, dtype=torch.float32),\\n\",\n",
    "    \"        torch.arange(x_min, x_max, device=dev, dtype=torch.float32), indexing='ij')\\n\",\n",
    "    \"    pixels = torch.stack([gx, gy], -1).reshape(-1, 1, 2)\\n\",\n",
    "    \"    dist_sq = ((pixels - pts.unsqueeze(0))**2).sum(-1).min(1).values\\n\",\n",
    "    \"    canvas[y_min:y_max, x_min:x_max] = torch.exp(-dist_sq / (2*sig*sig)).reshape(y_max-y_min, x_max-x_min)\\n\",\n",
    "    \"    return canvas.clamp(0, 1)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 6. DiffAlign — Loss Functions (Eq 3-8)\\n\",\n",
    "    \"\\n\",\n",
    "    \"Five loss terms from the DOGE paper that jointly optimize geometry.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Loss weights from paper (Section 4.1)\\n\",\n",
    "    \"LAMBDA_COVER = 1.0\\n\",\n",
    "    \"LAMBDA_OVERLAP = 0.3\\n\",\n",
    "    \"LAMBDA_G1 = 0.012\\n\",\n",
    "    \"LAMBDA_OFFSET = 0.006\\n\",\n",
    "    \"LAMBDA_SPACING = 0.006\\n\",\n",
    "    \"N_SAMPLES = 48\\n\",\n",
    "    \"\\n\",\n",
    "    \"def loss_coverage(rendered, target):\\n\",\n",
    "    \"    \\\"\\\"\\\"Eq 4: pixel-wise L2.\\\"\\\"\\\"\\n\",\n",
    "    \"    return F.mse_loss(rendered, target)\\n\",\n",
    "    \"\\n\",\n",
    "    \"def loss_overlap(graph, H, W, max_edges=80):\\n\",\n",
    "    \"    \\\"\\\"\\\"Eq 5: penalize multi-covered pixels.\\\"\\\"\\\"\\n\",\n",
    "    \"    N = graph.n_edges\\n\",\n",
    "    \"    if N <= 1: return torch.tensor(0.0, device=graph.node_positions.device)\\n\",\n",
    "    \"    edge_list = list(range(min(N, max_edges)))\\n\",\n",
    "    \"    s = torch.zeros(H, W, device=graph.node_positions.device)\\n\",\n",
    "    \"    for e in edge_list:\\n\",\n",
    "    \"        s = s + render_single_edge(graph, e, H, W, n_samples=32)\\n\",\n",
    "    \"    return torch.clamp(s - 1.0, min=0).mean()\\n\",\n",
    "    \"\\n\",\n",
    "    \"def loss_g1(graph, threshold_deg=160.0):\\n\",\n",
    "    \"    \\\"\\\"\\\"Eq 6: tangent alignment at degree-2 nodes.\\\"\\\"\\\"\\n\",\n",
    "    \"    if graph.n_nodes == 0 or graph.n_edges < 2:\\n\",\n",
    "    \"        return torch.tensor(0.0, device=graph.node_positions.device)\\n\",\n",
    "    \"    deg = graph.node_degree()\\n\",\n",
    "    \"    deg2 = torch.where(deg == 2)[0]\\n\",\n",
    "    \"    if len(deg2) == 0:\\n\",\n",
    "    \"        return torch.tensor(0.0, device=graph.node_positions.device)\\n\",\n",
    "    \"    st, et = graph.get_edge_tangents()\\n\",\n",
    "    \"    threshold_rad = threshold_deg * np.pi / 180.0\\n\",\n",
    "    \"    loss_sum = torch.tensor(0.0, device=graph.node_positions.device)\\n\",\n",
    "    \"    count = 0\\n\",\n",
    "    \"    for ni in deg2.tolist():\\n\",\n",
    "    \"        edges = graph.edges_at_node(ni)\\n\",\n",
    "    \"        if len(edges) != 2: continue\\n\",\n",
    "    \"        e1, s1 = edges[0]; e2, s2 = edges[1]\\n\",\n",
    "    \"        t1 = st[e1] if s1 else -et[e1]\\n\",\n",
    "    \"        t2 = st[e2] if s2 else -et[e2]\\n\",\n",
    "    \"        t1n = t1 / (torch.norm(t1) + 1e-8)\\n\",\n",
    "    \"        t2n = t2 / (torch.norm(t2) + 1e-8)\\n\",\n",
    "    \"        cos_a = torch.dot(t1n, t2n).clamp(-1, 1)\\n\",\n",
    "    \"        angle = torch.acos(cos_a)\\n\",\n",
    "    \"        if angle.item() < threshold_rad:\\n\",\n",
    "    \"            loss_sum = loss_sum + (1.0 - cos_a)\\n\",\n",
    "    \"            count += 1\\n\",\n",
    "    \"    return loss_sum / max(count, 1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"def loss_offset(graph, tau=0.5):\\n\",\n",
    "    \"    \\\"\\\"\\\"Eq 7: penalize excessive control point offsets.\\\"\\\"\\\"\\n\",\n",
    "    \"    if graph.n_edges == 0:\\n\",\n",
    "    \"        return torch.tensor(0.0, device=graph.node_positions.device)\\n\",\n",
    "    \"    idx = graph.edge_indices\\n\",\n",
    "    \"    L = torch.norm(graph.node_positions[idx[:,1]] - graph.node_positions[idx[:,0]], dim=1).clamp(min=1e-6)\\n\",\n",
    "    \"    ratios = torch.abs(graph.edge_offset) / L.unsqueeze(1)\\n\",\n",
    "    \"    return torch.clamp(torch.exp(ratios - tau) - 1.0, min=0).mean()\\n\",\n",
    "    \"\\n\",\n",
    "    \"def loss_spacing(graph):\\n\",\n",
    "    \"    \\\"\\\"\\\"Eq 8: encourage equidistant control point placement.\\\"\\\"\\\"\\n\",\n",
    "    \"    if graph.n_edges == 0:\\n\",\n",
    "    \"        return torch.tensor(0.0, device=graph.node_positions.device)\\n\",\n",
    "    \"    a = graph.edge_alpha\\n\",\n",
    "    \"    return ((a[:, 0] - 1/3)**2 + (a[:, 1] - 2/3)**2).mean()\\n\",\n",
    "    \"\\n\",\n",
    "    \"def compute_losses(graph, target, rendered):\\n\",\n",
    "    \"    \\\"\\\"\\\"Eq 3: composite loss.\\\"\\\"\\\"\\n\",\n",
    "    \"    H, W = target.shape\\n\",\n",
    "    \"    l_c = loss_coverage(rendered, target)\\n\",\n",
    "    \"    l_o = loss_overlap(graph, H, W) if graph.n_edges > 1 else torch.tensor(0.0, device=target.device)\\n\",\n",
    "    \"    l_g = loss_g1(graph)\\n\",\n",
    "    \"    l_off = loss_offset(graph)\\n\",\n",
    "    \"    l_sp = loss_spacing(graph)\\n\",\n",
    "    \"    total = (LAMBDA_COVER*l_c + LAMBDA_OVERLAP*l_o + LAMBDA_G1*l_g\\n\",\n",
    "    \"             + LAMBDA_OFFSET*l_off + LAMBDA_SPACING*l_sp)\\n\",\n",
    "    \"    return total, {'total': total.item(), 'cover': l_c.item(), 'overlap': l_o.item(),\\n\",\n",
    "    \"                   'g1': l_g.item(), 'offset': l_off.item(), 'spacing': l_sp.item()}\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 7. TopoAdapt — Topology Operators (Section 3.3)\\n\",\n",
    "    \"\\n\",\n",
    "    \"Five discrete operators that refine the graph's connectivity between gradient steps.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"MERGE_DIST = 4.0  # pixels (~meters at 1m/px)\\n\",\n",
    "    \"NEW_ROAD_LEN = 40.0\\n\",\n",
    "    \"NEW_ROAD_WIDTH = 3.0\\n\",\n",
    "    \"MAX_NEW_ROADS = 10\\n\",\n",
    "    \"MIN_EDGE_LEN = 5.0\\n\",\n",
    "    \"COLLINEAR_THRESH_DEG = 160.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def op_road_addition(graph, target, max_new=MAX_NEW_ROADS):\\n\",\n",
    "    \"    \\\"\\\"\\\"Eq 9-10: seed edges in uncovered road regions.\\\"\\\"\\\"\\n\",\n",
    "    \"    H, W = target.shape\\n\",\n",
    "    \"    dev = graph.node_positions.device\\n\",\n",
    "    \"    with torch.no_grad():\\n\",\n",
    "    \"        rendered = render_graph(graph, H, W, n_samples=32).cpu().numpy()\\n\",\n",
    "    \"    target_np = target.detach().cpu().numpy()\\n\",\n",
    "    \"    unfit = ((target_np > 0.5) & (rendered < 0.3)).astype(np.float32)\\n\",\n",
    "    \"    labeled, n_comp = nd_label(unfit)\\n\",\n",
    "    \"    if n_comp == 0: return 0\\n\",\n",
    "    \"    centers, sizes = [], []\\n\",\n",
    "    \"    for c in range(1, n_comp + 1):\\n\",\n",
    "    \"        m = labeled == c\\n\",\n",
    "    \"        sz = m.sum()\\n\",\n",
    "    \"        if sz < 10: continue\\n\",\n",
    "    \"        ys, xs = np.where(m)\\n\",\n",
    "    \"        centers.append((xs.mean(), ys.mean()))\\n\",\n",
    "    \"        sizes.append(sz)\\n\",\n",
    "    \"    if not centers: return 0\\n\",\n",
    "    \"    order = np.argsort(sizes)[::-1][:max_new]\\n\",\n",
    "    \"    added = 0\\n\",\n",
    "    \"    for i in order:\\n\",\n",
    "    \"        cx, cy = centers[i]\\n\",\n",
    "    \"        if graph.n_nodes > 0:\\n\",\n",
    "    \"            pos_np = graph.node_positions.detach().cpu().numpy()\\n\",\n",
    "    \"            if np.sqrt((pos_np[:,0]-cx)**2+(pos_np[:,1]-cy)**2).min() < MERGE_DIST*2:\\n\",\n",
    "    \"                continue\\n\",\n",
    "    \"        angle = np.random.uniform(0, np.pi)\\n\",\n",
    "    \"        hl = NEW_ROAD_LEN / 2\\n\",\n",
    "    \"        x0 = float(np.clip(cx - hl*np.cos(angle), 1, W-2))\\n\",\n",
    "    \"        y0 = float(np.clip(cy - hl*np.sin(angle), 1, H-2))\\n\",\n",
    "    \"        x1 = float(np.clip(cx + hl*np.cos(angle), 1, W-2))\\n\",\n",
    "    \"        y1 = float(np.clip(cy + hl*np.sin(angle), 1, H-2))\\n\",\n",
    "    \"        nids = graph.add_nodes(torch.tensor([[x0,y0],[x1,y1]], device=dev))\\n\",\n",
    "    \"        graph.add_edges(nids[0:1], nids[1:2], widths=torch.tensor([NEW_ROAD_WIDTH], device=dev))\\n\",\n",
    "    \"        added += 1\\n\",\n",
    "    \"    return added\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def op_node_merging(graph):\\n\",\n",
    "    \"    \\\"\\\"\\\"Merge nodes closer than MERGE_DIST.\\\"\\\"\\\"\\n\",\n",
    "    \"    if graph.n_nodes < 2: return 0\\n\",\n",
    "    \"    pos = graph.node_positions.detach().cpu().numpy()\\n\",\n",
    "    \"    tree = cKDTree(pos)\\n\",\n",
    "    \"    pairs = tree.query_pairs(r=MERGE_DIST)\\n\",\n",
    "    \"    if not pairs: return 0\\n\",\n",
    "    \"    parent = list(range(graph.n_nodes))\\n\",\n",
    "    \"    def find(x):\\n\",\n",
    "    \"        while parent[x] != x: parent[x] = parent[parent[x]]; x = parent[x]\\n\",\n",
    "    \"        return x\\n\",\n",
    "    \"    for i, j in pairs: ri, rj = find(i), find(j); parent[rj] = ri if ri != rj else parent[rj]\\n\",\n",
    "    \"    canonical = {i: find(i) for i in range(graph.n_nodes)}\\n\",\n",
    "    \"    if len(set(canonical.values())) == graph.n_nodes: return 0\\n\",\n",
    "    \"    root_pos = {}\\n\",\n",
    "    \"    for i in range(graph.n_nodes):\\n\",\n",
    "    \"        r = canonical[i]\\n\",\n",
    "    \"        root_pos.setdefault(r, []).append(pos[i])\\n\",\n",
    "    \"    r2new = {}; new_pos = []\\n\",\n",
    "    \"    for r in sorted(root_pos): r2new[r] = len(new_pos); new_pos.append(np.mean(root_pos[r], axis=0))\\n\",\n",
    "    \"    o2n = {i: r2new[canonical[i]] for i in range(graph.n_nodes)}\\n\",\n",
    "    \"    dev = graph.node_positions.device\\n\",\n",
    "    \"    new_pos_t = torch.tensor(np.array(new_pos, dtype=np.float32), device=dev)\\n\",\n",
    "    \"    if graph.n_edges > 0:\\n\",\n",
    "    \"        old_e = graph.edge_indices.cpu().numpy()\\n\",\n",
    "    \"        new_e = np.array([[o2n[int(u)], o2n[int(v)]] for u,v in old_e], dtype=np.int64)\\n\",\n",
    "    \"        valid = new_e[:,0] != new_e[:,1]\\n\",\n",
    "    \"        graph.edge_indices = torch.tensor(new_e[valid], device=dev, dtype=torch.long)\\n\",\n",
    "    \"        vt = torch.tensor(valid, device=dev, dtype=torch.bool)\\n\",\n",
    "    \"        graph.edge_alpha = nn.Parameter(graph.edge_alpha.data[vt])\\n\",\n",
    "    \"        graph.edge_offset = nn.Parameter(graph.edge_offset.data[vt])\\n\",\n",
    "    \"        graph.edge_width = nn.Parameter(graph.edge_width.data[vt])\\n\",\n",
    "    \"        graph._n_edges = int(valid.sum())\\n\",\n",
    "    \"    graph.node_positions = nn.Parameter(new_pos_t)\\n\",\n",
    "    \"    graph._n_nodes = len(new_pos)\\n\",\n",
    "    \"    return len(pairs)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def op_t_junction(graph, n_samples=32):\\n\",\n",
    "    \"    \\\"\\\"\\\"Snap degree-1 nodes to nearby edges.\\\"\\\"\\\"\\n\",\n",
    "    \"    if graph.n_nodes < 1 or graph.n_edges < 1: return 0\\n\",\n",
    "    \"    pos = graph.node_positions.detach().cpu().numpy()\\n\",\n",
    "    \"    deg = graph.node_degree().cpu().numpy()\\n\",\n",
    "    \"    candidates = np.where(deg == 1)[0]\\n\",\n",
    "    \"    if len(candidates) == 0: return 0\\n\",\n",
    "    \"    with torch.no_grad():\\n\",\n",
    "    \"        all_pts = graph.sample_curves(n_samples=n_samples).cpu().numpy()\\n\",\n",
    "    \"    created = 0\\n\",\n",
    "    \"    for ni in candidates:\\n\",\n",
    "    \"        np_ = pos[ni]\\n\",\n",
    "    \"        connected = set(e for e, _ in graph.edges_at_node(ni))\\n\",\n",
    "    \"        best_d, best_e = float('inf'), -1\\n\",\n",
    "    \"        for e in range(graph.n_edges):\\n\",\n",
    "    \"            if e in connected: continue\\n\",\n",
    "    \"            d = np.sqrt(np.sum((all_pts[e] - np_)**2, axis=1)).min()\\n\",\n",
    "    \"            if d < best_d: best_d, best_e = d, e\\n\",\n",
    "    \"        if best_e < 0 or best_d > MERGE_DIST: continue\\n\",\n",
    "    \"        es = int(graph.edge_indices[best_e, 0].item())\\n\",\n",
    "    \"        ee = int(graph.edge_indices[best_e, 1].item())\\n\",\n",
    "    \"        ds = np.linalg.norm(pos[es] - np_)\\n\",\n",
    "    \"        de = np.linalg.norm(pos[ee] - np_)\\n\",\n",
    "    \"        tgt = es if ds <= de else ee\\n\",\n",
    "    \"        if tgt == ni: continue\\n\",\n",
    "    \"        exists = any((graph.edge_indices[e,0].item()==ni and graph.edge_indices[e,1].item()==tgt) or\\n\",\n",
    "    \"                     (graph.edge_indices[e,0].item()==tgt and graph.edge_indices[e,1].item()==ni)\\n\",\n",
    "    \"                     for e in range(graph.n_edges))\\n\",\n",
    "    \"        if exists: continue\\n\",\n",
    "    \"        dev = graph.node_positions.device\\n\",\n",
    "    \"        graph.add_edges(torch.tensor([ni],device=dev), torch.tensor([tgt],device=dev),\\n\",\n",
    "    \"                        widths=torch.tensor([graph.edge_width[best_e].item()],device=dev))\\n\",\n",
    "    \"        created += 1\\n\",\n",
    "    \"    return created\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def op_edge_pruning(graph):\\n\",\n",
    "    \"    \\\"\\\"\\\"Remove too-short or too-thin edges.\\\"\\\"\\\"\\n\",\n",
    "    \"    if graph.n_edges == 0: return 0\\n\",\n",
    "    \"    with torch.no_grad():\\n\",\n",
    "    \"        idx = graph.edge_indices\\n\",\n",
    "    \"        chord = torch.norm(graph.node_positions[idx[:,1]] - graph.node_positions[idx[:,0]], dim=1)\\n\",\n",
    "    \"        remove = (chord < MIN_EDGE_LEN) | (graph.edge_width < 1.0)\\n\",\n",
    "    \"    n = int(remove.sum().item())\\n\",\n",
    "    \"    if n > 0:\\n\",\n",
    "    \"        graph.remove_edges(remove)\\n\",\n",
    "    \"        graph.remove_isolated_nodes()\\n\",\n",
    "    \"    return n\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def topoadapt_step(graph, target, iteration):\\n\",\n",
    "    \"    \\\"\\\"\\\"Run all topology operators.\\\"\\\"\\\"\\n\",\n",
    "    \"    stats = {}\\n\",\n",
    "    \"    stats['pruned'] = op_edge_pruning(graph)\\n\",\n",
    "    \"    stats['merged'] = op_node_merging(graph)\\n\",\n",
    "    \"    if iteration < 200 and iteration % 5 == 0:\\n\",\n",
    "    \"        stats['added'] = op_road_addition(graph, target)\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        stats['added'] = 0\\n\",\n",
    "    \"    if iteration >= 10 and iteration % 10 == 0:\\n\",\n",
    "    \"        stats['t_junc'] = op_t_junction(graph)\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        stats['t_junc'] = 0\\n\",\n",
    "    \"    return stats\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 8. DOGE Optimizer — Algorithm 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"The main loop: alternate TopoAdapt (topology) and DiffAlign (geometry).\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"T_MAX = 120           # Max iterations per tile\\n\",\n",
    "    \"LR = 0.5              # Learning rate\\n\",\n",
    "    \"LR_DECAY = 0.995\\n\",\n",
    "    \"DIFFALIGN_STEPS = 5   # Gradient steps per topo step\\n\",\n",
    "    \"TOPO_INTERVAL = 10    # TopoAdapt every N iters\\n\",\n",
    "    \"PATIENCE = 25\\n\",\n",
    "    \"MAX_INITIAL_SEEDS = 25\\n\",\n",
    "    \"LOG_INTERVAL = 20\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def initialize_graph(target_t):\\n\",\n",
    "    \"    \\\"\\\"\\\"Seed initial edges in high-density regions.\\\"\\\"\\\"\\n\",\n",
    "    \"    H, W = target_t.shape\\n\",\n",
    "    \"    dev = target_t.device\\n\",\n",
    "    \"    graph = BezierGraph(H, W).to(dev)\\n\",\n",
    "    \"    target_np = target_t.cpu().numpy()\\n\",\n",
    "    \"    unfit = (target_np > 0.3).astype(np.float32)\\n\",\n",
    "    \"    labeled, n_comp = nd_label(unfit)\\n\",\n",
    "    \"    centers, sizes = [], []\\n\",\n",
    "    \"    for c in range(1, n_comp + 1):\\n\",\n",
    "    \"        m = labeled == c\\n\",\n",
    "    \"        sz = m.sum()\\n\",\n",
    "    \"        if sz < 10: continue\\n\",\n",
    "    \"        ys, xs = np.where(m)\\n\",\n",
    "    \"        centers.append((xs.mean(), ys.mean()))\\n\",\n",
    "    \"        sizes.append(sz)\\n\",\n",
    "    \"    order = np.argsort(sizes)[::-1][:MAX_INITIAL_SEEDS]\\n\",\n",
    "    \"    for i in order:\\n\",\n",
    "    \"        cx, cy = centers[i]\\n\",\n",
    "    \"        angle = np.random.uniform(0, np.pi)\\n\",\n",
    "    \"        hl = NEW_ROAD_LEN / 2\\n\",\n",
    "    \"        x0 = float(np.clip(cx - hl*np.cos(angle), 1, W-2))\\n\",\n",
    "    \"        y0 = float(np.clip(cy - hl*np.sin(angle), 1, H-2))\\n\",\n",
    "    \"        x1 = float(np.clip(cx + hl*np.cos(angle), 1, W-2))\\n\",\n",
    "    \"        y1 = float(np.clip(cy + hl*np.sin(angle), 1, H-2))\\n\",\n",
    "    \"        nids = graph.add_nodes(torch.tensor([[x0,y0],[x1,y1]], device=dev))\\n\",\n",
    "    \"        graph.add_edges(nids[0:1], nids[1:2], widths=torch.tensor([NEW_ROAD_WIDTH], device=dev))\\n\",\n",
    "    \"    print(f'  [init] Seeded {graph.n_edges} edges')\\n\",\n",
    "    \"    return graph\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def optimize_tile(target_np):\\n\",\n",
    "    \"    \\\"\\\"\\\"Full DOGE optimization loop for one tile (Algorithm 1).\\\"\\\"\\\"\\n\",\n",
    "    \"    dev = torch.device(DEVICE)\\n\",\n",
    "    \"    target_t = torch.tensor(target_np, dtype=torch.float32, device=dev)\\n\",\n",
    "    \"    H, W = target_t.shape\\n\",\n",
    "    \"\\n\",\n",
    "    \"    graph = initialize_graph(target_t)\\n\",\n",
    "    \"    if graph.n_edges == 0:\\n\",\n",
    "    \"        return graph, []\\n\",\n",
    "    \"\\n\",\n",
    "    \"    history = []\\n\",\n",
    "    \"    best_loss, patience_ctr = float('inf'), 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for t in range(T_MAX):\\n\",\n",
    "    \"        # TopoAdapt phase\\n\",\n",
    "    \"        if t % TOPO_INTERVAL == 0:\\n\",\n",
    "    \"            with torch.no_grad():\\n\",\n",
    "    \"                stats = topoadapt_step(graph, target_t, t)\\n\",\n",
    "    \"            if graph.n_edges == 0:\\n\",\n",
    "    \"                graph = initialize_graph(target_t)\\n\",\n",
    "    \"                if graph.n_edges == 0: break\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Rebuild optimizer after topo changes\\n\",\n",
    "    \"        if t % TOPO_INTERVAL == 0 or t == 0:\\n\",\n",
    "    \"            lr = LR * (LR_DECAY ** t)\\n\",\n",
    "    \"            optimizer = torch.optim.Adam(graph.get_optimizable_params(), lr=lr)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # DiffAlign phase\\n\",\n",
    "    \"        for _ in range(DIFFALIGN_STEPS):\\n\",\n",
    "    \"            optimizer.zero_grad()\\n\",\n",
    "    \"            try:\\n\",\n",
    "    \"                rendered = render_graph(graph, H, W, n_samples=N_SAMPLES)\\n\",\n",
    "    \"                total_loss, ld = compute_losses(graph, target_t, rendered)\\n\",\n",
    "    \"                total_loss.backward()\\n\",\n",
    "    \"                torch.nn.utils.clip_grad_norm_(graph.parameters(), 10.0)\\n\",\n",
    "    \"                optimizer.step()\\n\",\n",
    "    \"            except RuntimeError as e:\\n\",\n",
    "    \"                if 'out of memory' in str(e).lower():\\n\",\n",
    "    \"                    torch.cuda.empty_cache()\\n\",\n",
    "    \"                    break\\n\",\n",
    "    \"                raise\\n\",\n",
    "    \"            with torch.no_grad():\\n\",\n",
    "    \"                graph.edge_alpha.data.clamp_(0, 1)\\n\",\n",
    "    \"                graph.edge_width.data.clamp_(min=0.5)\\n\",\n",
    "    \"                graph.node_positions.data[:, 0].clamp_(0, W-1)\\n\",\n",
    "    \"                graph.node_positions.data[:, 1].clamp_(0, H-1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        history.append({'iter': t, **ld, 'nodes': graph.n_nodes, 'edges': graph.n_edges})\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if t % LOG_INTERVAL == 0:\\n\",\n",
    "    \"            print(f'    iter {t:3d} | loss={ld[\\\"total\\\"]:.4f} (cover={ld[\\\"cover\\\"]:.4f}) | '\\n\",\n",
    "    \"                  f'{graph.n_nodes}N {graph.n_edges}E')\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Early stopping\\n\",\n",
    "    \"        if ld['total'] < best_loss - 1e-5:\\n\",\n",
    "    \"            best_loss = ld['total']; patience_ctr = 0\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            patience_ctr += 1\\n\",\n",
    "    \"        if patience_ctr >= PATIENCE:\\n\",\n",
    "    \"            print(f'    Early stop at iter {t}')\\n\",\n",
    "    \"            break\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(f'  Final: {graph}')\\n\",\n",
    "    \"    return graph, history\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 9. Run Optimization on All Tiles\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Optional: limit tiles for quick testing\\n\",\n",
    "    \"MAX_TILES = None  # Set to e.g. 5 for quick test, None for full run\\n\",\n",
    "    \"\\n\",\n",
    "    \"run_tiles = tiles[:MAX_TILES] if MAX_TILES else tiles\\n\",\n",
    "    \"print(f'Optimizing {len(run_tiles)} tiles...')\\n\",\n",
    "    \"\\n\",\n",
    "    \"tile_results = []\\n\",\n",
    "    \"all_history = []\\n\",\n",
    "    \"t0 = time.time()\\n\",\n",
    "    \"\\n\",\n",
    "    \"for i, tile in enumerate(run_tiles):\\n\",\n",
    "    \"    print(f'\\\\n=== Tile {i+1}/{len(run_tiles)} (r={tile.row}, c={tile.col}, cov={tile.coverage:.1%}) ===')\\n\",\n",
    "    \"    try:\\n\",\n",
