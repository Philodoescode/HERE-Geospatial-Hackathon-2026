    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 1. Data Loading\\n\",\n",
    "    \"\\n\",\n",
    "    \"Upload your data to Kaggle as a dataset, then set `DATA_DIR` below.\\n\",\n",
    "    \"Expected structure:\\n\",\n",
    "    \"```\\n\",\n",
    "    \"DATA_DIR/\\n\",\n",
    "    \"  Kosovo_VPD/Kosovo_VPD.parquet\\n\",\n",
    "    \"  Kosovo_HPD/XKO_HPD_week_1.parquet\\n\",\n",
    "    \"  Kosovo_HPD/XKO_HPD_week_2.parquet\\n\",\n",
    "    \"  Kosovo's nav streets/nav_kosovo.parquet   (ground truth, optional)\\n\",\n",
    "    \"```\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-02-11T15:23:28.682703Z\",\n",
    "     \"start_time\": \"2026-02-11T15:23:28.657734Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# === CONFIGURE THESE PATHS ===\\n\",\n",
    "    \"DATA_DIR = Path('Data')\\n\",\n",
    "    \"OUTPUT_DIR = Path('outputs/bezier_doge_output')\\n\",\n",
    "    \"OUTPUT_DIR.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Kosovo bounding box (WGS84)\\n\",\n",
    "    \"BBOX = (21.088588, 42.571255, 21.188588, 42.671255)\\n\",\n",
    "    \"UTM_EPSG = 32634  # UTM zone 34N\\n\",\n",
    "    \"RESOLUTION_M = 1.0  # meters per pixel\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 8\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-02-11T15:23:28.743717Z\",\n",
    "     \"start_time\": \"2026-02-11T15:23:28.693702Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"def parse_wkt_multi(text):\\n\",\n",
    "    \"    \\\"\\\"\\\"Parse WKT string into list of LineStrings.\\\"\\\"\\\"\\n\",\n",
    "    \"    if text is None or (isinstance(text, float) and np.isnan(text)):\\n\",\n",
    "    \"        return []\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        geom = wkt.loads(str(text))\\n\",\n",
    "    \"    except Exception:\\n\",\n",
    "    \"        return []\\n\",\n",
    "    \"    if geom is None or geom.is_empty:\\n\",\n",
    "    \"        return []\\n\",\n",
    "    \"    if isinstance(geom, LineString):\\n\",\n",
    "    \"        return [geom]\\n\",\n",
    "    \"    if isinstance(geom, MultiLineString):\\n\",\n",
    "    \"        return [g for g in geom.geoms if isinstance(g, LineString) and not g.is_empty]\\n\",\n",
    "    \"    return []\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def clip_line(geom, clip_poly):\\n\",\n",
    "    \"    \\\"\\\"\\\"Clip LineString to polygon, return largest piece.\\\"\\\"\\\"\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        clipped = geom.intersection(clip_poly)\\n\",\n",
    "    \"    except Exception:\\n\",\n",
    "    \"        return None\\n\",\n",
    "    \"    if clipped is None or clipped.is_empty:\\n\",\n",
    "    \"        return None\\n\",\n",
    "    \"    if isinstance(clipped, LineString):\\n\",\n",
    "    \"        return clipped\\n\",\n",
    "    \"    if isinstance(clipped, MultiLineString):\\n\",\n",
    "    \"        parts = [g for g in clipped.geoms if isinstance(g, LineString) and not g.is_empty]\\n\",\n",
    "    \"        return max(parts, key=lambda g: g.length) if parts else None\\n\",\n",
    "    \"    return None\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def load_vpd(path, bbox, fused_only=True):\\n\",\n",
    "    \"    \\\"\\\"\\\"Load VPD traces clipped to bbox.\\\"\\\"\\\"\\n\",\n",
    "    \"    suffix = path.suffix.lower()\\n\",\n",
    "    \"    usecols = ['driveid', 'fused', 'path']\\n\",\n",
    "    \"    df = pd.read_parquet(path, columns=usecols) if suffix == '.parquet' else pd.read_csv(path, usecols=usecols)\\n\",\n",
    "    \"    if fused_only and 'fused' in df.columns:\\n\",\n",
    "    \"        df = df[df['fused'].astype(str).str.lower().isin({'yes', 'true', '1'})]\\n\",\n",
    "    \"    clip_poly = box(*bbox)\\n\",\n",
    "    \"    lines = []\\n\",\n",
    "    \"    for _, row in df.iterrows():\\n\",\n",
    "    \"        for geom in parse_wkt_multi(row.get('path')):\\n\",\n",
    "    \"            c = clip_line(geom, clip_poly)\\n\",\n",
    "    \"            if c is not None and c.length > 0:\\n\",\n",
    "    \"                lines.append(c)\\n\",\n",
    "    \"    return lines\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def load_hpd(paths, bbox):\\n\",\n",
    "    \"    \\\"\\\"\\\"Load HPD probe points, group by trace, form LineStrings.\\\"\\\"\\\"\\n\",\n",
    "    \"    usecols = ['heading', 'latitude', 'longitude', 'traceid', 'speed', 'day', 'time']\\n\",\n",
    "    \"    frames = []\\n\",\n",
    "    \"    for p in paths:\\n\",\n",
    "    \"        suffix = p.suffix.lower()\\n\",\n",
    "    \"        sub = pd.read_parquet(p, columns=usecols) if suffix == '.parquet' else pd.read_csv(p, usecols=usecols)\\n\",\n",
    "    \"        sub['latitude'] = pd.to_numeric(sub['latitude'], errors='coerce')\\n\",\n",
    "    \"        sub['longitude'] = pd.to_numeric(sub['longitude'], errors='coerce')\\n\",\n",
    "    \"        sub['day'] = pd.to_numeric(sub['day'], errors='coerce')\\n\",\n",
    "    \"        sub = sub.dropna(subset=['latitude', 'longitude', 'traceid', 'time'])\\n\",\n",
    "    \"        frames.append(sub)\\n\",\n",
    "    \"    if not frames:\\n\",\n",
    "    \"        return []\\n\",\n",
    "    \"    all_pts = pd.concat(frames, ignore_index=True)\\n\",\n",
    "    \"    all_pts['time'] = pd.to_datetime(all_pts['time'], format='%H:%M:%S', errors='coerce')\\n\",\n",
    "    \"    all_pts = all_pts.dropna(subset=['time'])\\n\",\n",
    "    \"    clip_poly = box(*bbox)\\n\",\n",
    "    \"    lines = []\\n\",\n",
    "    \"    for _, grp in all_pts.sort_values(['traceid', 'day', 'time']).groupby(['traceid', 'day'], sort=False):\\n\",\n",
    "    \"        if len(grp) < 2:\\n\",\n",
    "    \"            continue\\n\",\n",
    "    \"        coords = list(zip(grp['longitude'].tolist(), grp['latitude'].tolist()))\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            geom = LineString(coords)\\n\",\n",
    "    \"        except Exception:\\n\",\n",
    "    \"            continue\\n\",\n",
    "    \"        if geom.is_empty or geom.length == 0:\\n\",\n",
    "    \"            continue\\n\",\n",
    "    \"        c = clip_line(geom, clip_poly)\\n\",\n",
    "    \"        if c is not None and c.length > 0:\\n\",\n",
    "    \"            lines.append(c)\\n\",\n",
    "    \"    return lines\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 9\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-02-11T15:23:29.011707Z\",\n",
    "     \"start_time\": \"2026-02-11T15:23:28.754704Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# Find data files\\n\",\n",
    "    \"vpd_dir = DATA_DIR / 'Kosovo_VPD'\\n\",\n",
    "    \"hpd_dir = DATA_DIR / 'Kosovo_HPD'\\n\",\n",
    "    \"\\n\",\n",
    "    \"vpd_file = next((f for ext in ['.parquet', '.csv'] for f in vpd_dir.glob(f'*{ext}')), None)\\n\",\n",
    "    \"hpd_files = sorted([f for ext in ['.parquet', '.csv'] for f in hpd_dir.glob(f'*{ext}')])\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f'VPD file: {vpd_file}')\\n\",\n",
    "    \"print(f'HPD files: {hpd_files}')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Load traces\\n\",\n",
    "    \"vpd_lines = load_vpd(vpd_file, BBOX) if vpd_file else []\\n\",\n",
    "    \"hpd_lines = load_hpd(hpd_files, BBOX) if hpd_files else []\\n\",\n",
    "    \"print(f'\\\\nLoaded {len(vpd_lines)} VPD traces, {len(hpd_lines)} HPD traces')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Project to UTM and clean\\n\",\n",
    "    \"utm_crs = CRS.from_epsg(UTM_EPSG)\\n\",\n",
    "    \"to_utm = Transformer.from_crs(CRS.from_epsg(4326), utm_crs, always_xy=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"lines_utm, sources = [], []\\n\",\n",
    "    \"for geom in vpd_lines:\\n\",\n",
    "    \"    proj = transform(to_utm.transform, geom)\\n\",\n",
    "    \"    if not proj.is_empty and proj.length >= 10:\\n\",\n",
    "    \"        s = proj.simplify(1.5, preserve_topology=False)\\n\",\n",
    "    \"        if isinstance(s, LineString) and not s.is_empty and len(s.coords) >= 2:\\n\",\n",
    "    \"            proj = s\\n\",\n",
    "    \"        lines_utm.append(proj)\\n\",\n",
    "    \"        sources.append('VPD')\\n\",\n",
    "    \"\\n\",\n",
    "    \"for geom in hpd_lines:\\n\",\n",
    "    \"    proj = transform(to_utm.transform, geom)\\n\",\n",
    "    \"    if not proj.is_empty and proj.length >= 10:\\n\",\n",
    "    \"        s = proj.simplify(3.0, preserve_topology=False)\\n\",\n",
    "    \"        if isinstance(s, LineString) and not s.is_empty and len(s.coords) >= 2:\\n\",\n",
    "    \"            proj = s\\n\",\n",
    "    \"        lines_utm.append(proj)\\n\",\n",
    "    \"        sources.append('HPD')\\n\",\n",
    "    \"\\n\",\n",
    "    \"n_vpd = sum(1 for s in sources if s == 'VPD')\\n\",\n",
    "    \"n_hpd = sum(1 for s in sources if s == 'HPD')\\n\",\n",
    "    \"print(f'After projection: {n_vpd} VPD, {n_hpd} HPD traces')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Compute UTM bounds\\n\",\n",
    "    \"all_coords = np.vstack([np.array(l.coords) for l in lines_utm])\\n\",\n",
    "    \"utm_bounds = (all_coords[:,0].min(), all_coords[:,1].min(),\\n\",\n",
    "    \"              all_coords[:,0].max(), all_coords[:,1].max())\\n\",\n",
    "    \"print(f'UTM bounds: {utm_bounds}')\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"VPD file: None\\n\",\n",
    "      \"HPD files: []\\n\",\n",
    "      \"\\n\",\n",
    "      \"Loaded 0 VPD traces, 0 HPD traces\\n\",\n",
    "      \"After projection: 0 VPD, 0 HPD traces\\n\"\n",
    "     ]\n",
    "    },\n",
    "    {\n",
    "     \"ename\": \"ValueError\",\n",
    "     \"evalue\": \"need at least one array to concatenate\",\n",
    "     \"output_type\": \"error\",\n",
    "     \"traceback\": [\n",
    "      \"\\u001B[1;31m---------------------------------------------------------------------------\\u001B[0m\",\n",
    "      \"\\u001B[1;31mValueError\\u001B[0m                                Traceback (most recent call last)\",\n",
    "      \"Cell \\u001B[1;32mIn[10], line 44\\u001B[0m\\n\\u001B[0;32m     41\\u001B[0m \\u001B[38;5;28mprint\\u001B[39m(\\u001B[38;5;124mf\\u001B[39m\\u001B[38;5;124m'\\u001B[39m\\u001B[38;5;124mAfter projection: \\u001B[39m\\u001B[38;5;132;01m{\\u001B[39;00mn_vpd\\u001B[38;5;132;01m}\\u001B[39;00m\\u001B[38;5;124m VPD, \\u001B[39m\\u001B[38;5;132;01m{\\u001B[39;00mn_hpd\\u001B[38;5;132;01m}\\u001B[39;00m\\u001B[38;5;124m HPD traces\\u001B[39m\\u001B[38;5;124m'\\u001B[39m)\\n\\u001B[0;32m     43\\u001B[0m \\u001B[38;5;66;03m# Compute UTM bounds\\u001B[39;00m\\n\\u001B[1;32m---> 44\\u001B[0m all_coords \\u001B[38;5;241m=\\u001B[39m \\u001B[43mnp\\u001B[49m\\u001B[38;5;241;43m.\\u001B[39;49m\\u001B[43mvstack\\u001B[49m\\u001B[43m(\\u001B[49m\\u001B[43m[\\u001B[49m\\u001B[43mnp\\u001B[49m\\u001B[38;5;241;43m.\\u001B[39;49m\\u001B[43marray\\u001B[49m\\u001B[43m(\\u001B[49m\\u001B[43ml\\u001B[49m\\u001B[38;5;241;43m.\\u001B[39;49m\\u001B[43mcoords\\u001B[49m\\u001B[43m)\\u001B[49m\\u001B[43m \\u001B[49m\\u001B[38;5;28;43;01mfor\\u001B[39;49;00m\\u001B[43m \\u001B[49m\\u001B[43ml\\u001B[49m\\u001B[43m \\u001B[49m\\u001B[38;5;129;43;01min\\u001B[39;49;00m\\u001B[43m \\u001B[49m\\u001B[43mlines_utm\\u001B[49m\\u001B[43m]\\u001B[49m\\u001B[43m)\\u001B[49m\\n\\u001B[0;32m     45\\u001B[0m utm_bounds \\u001B[38;5;241m=\\u001B[39m (all_coords[:,\\u001B[38;5;241m0\\u001B[39m]\\u001B[38;5;241m.\\u001B[39mmin(), all_coords[:,\\u001B[38;5;241m1\\u001B[39m]\\u001B[38;5;241m.\\u001B[39mmin(),\\n\\u001B[0;32m     46\\u001B[0m               all_coords[:,\\u001B[38;5;241m0\\u001B[39m]\\u001B[38;5;241m.\\u001B[39mmax(), all_coords[:,\\u001B[38;5;241m1\\u001B[39m]\\u001B[38;5;241m.\\u001B[39mmax())\\n\\u001B[0;32m     47\\u001B[0m \\u001B[38;5;28mprint\\u001B[39m(\\u001B[38;5;124mf\\u001B[39m\\u001B[38;5;124m'\\u001B[39m\\u001B[38;5;124mUTM bounds: \\u001B[39m\\u001B[38;5;132;01m{\\u001B[39;00mutm_bounds\\u001B[38;5;132;01m}\\u001B[39;00m\\u001B[38;5;124m'\\u001B[39m)\\n\",\n",
    "      \"File \\u001B[1;32m~\\\\miniconda3\\\\envs\\\\here-env\\\\lib\\\\site-packages\\\\numpy\\\\_core\\\\shape_base.py:292\\u001B[0m, in \\u001B[0;36mvstack\\u001B[1;34m(tup, dtype, casting)\\u001B[0m\\n\\u001B[0;32m    290\\u001B[0m \\u001B[38;5;28;01mif\\u001B[39;00m \\u001B[38;5;129;01mnot\\u001B[39;00m \\u001B[38;5;28misinstance\\u001B[39m(arrs, \\u001B[38;5;28mtuple\\u001B[39m):\\n\\u001B[0;32m    291\\u001B[0m     arrs \\u001B[38;5;241m=\\u001B[39m (arrs,)\\n\\u001B[1;32m--> 292\\u001B[0m \\u001B[38;5;28;01mreturn\\u001B[39;00m \\u001B[43m_nx\\u001B[49m\\u001B[38;5;241;43m.\\u001B[39;49m\\u001B[43mconcatenate\\u001B[49m\\u001B[43m(\\u001B[49m\\u001B[43marrs\\u001B[49m\\u001B[43m,\\u001B[49m\\u001B[43m \\u001B[49m\\u001B[38;5;241;43m0\\u001B[39;49m\\u001B[43m,\\u001B[49m\\u001B[43m \\u001B[49m\\u001B[43mdtype\\u001B[49m\\u001B[38;5;241;43m=\\u001B[39;49m\\u001B[43mdtype\\u001B[49m\\u001B[43m,\\u001B[49m\\u001B[43m \\u001B[49m\\u001B[43mcasting\\u001B[49m\\u001B[38;5;241;43m=\\u001B[39;49m\\u001B[43mcasting\\u001B[49m\\u001B[43m)\\u001B[49m\\n\",\n",
    "      \"\\u001B[1;31mValueError\\u001B[0m: need at least one array to concatenate\"\n",
    "     ]\n",
    "    }\n",
