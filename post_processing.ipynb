    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-02-11T16:17:05.832725Z\",\n",
    "     \"start_time\": \"2026-02-11T16:16:55.793841Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"from shapely import MultiLineString\\n\",\n",
    "    \"import geopandas as gpd\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"from shapely.geometry import LineString, Point, MultiPoint\\n\",\n",
    "    \"from shapely.ops import unary_union, linemerge\\n\",\n",
    "    \"from scipy.spatial import cKDTree\\n\",\n",
    "    \"\\n\",\n",
    "    \"def post_process_roads(input_path, output_path, snap_dist=15.0, simplify_tol=2.0):\\n\",\n",
    "    \"    # 1. Load data and project to UTM for meter-based calculations\\n\",\n",
    "    \"    gdf = gpd.read_file(input_path)\\n\",\n",
    "    \"    original_crs = gdf.crs\\n\",\n",
    "    \"    # Project to a metric CRS (change EPSG:32634 if not in Kosovo region)\\n\",\n",
    "    \"    gdf = gdf.to_crs(epsg=32634)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(f\\\"Loaded {len(gdf)} segments. Consolidating nodes...\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 2. Node Snapping (Heal Intersections)\\n\",\n",
    "    \"    coords = []\\n\",\n",
    "    \"    for line in gdf.geometry:\\n\",\n",
    "    \"        coords.extend([line.coords[0], line.coords[-1]])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    unique_coords = np.array(coords)\\n\",\n",
    "    \"    tree = cKDTree(unique_coords)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Find clusters of endpoints\\n\",\n",
    "    \"    pairs = tree.query_pairs(r=snap_dist)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Basic Union-Find to group nodes\\n\",\n",
    "    \"    parent = {i: i for i in range(len(unique_coords))}\\n\",\n",
    "    \"    def find(i):\\n\",\n",
    "    \"        if parent[i] == i: return i\\n\",\n",
    "    \"        parent[i] = find(parent[i])\\n\",\n",
    "    \"        return parent[i]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for i, j in pairs:\\n\",\n",
    "    \"        root_i, root_j = find(i), find(j)\\n\",\n",
    "    \"        if root_i != root_j: parent[root_j] = root_i\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Compute cluster centroids\\n\",\n",
    "    \"    clusters = {}\\n\",\n",
    "    \"    for i in range(len(unique_coords)):\\n\",\n",
    "    \"        root = find(i)\\n\",\n",
    "    \"        clusters.setdefault(root, []).append(unique_coords[i])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    centroids = {root: np.mean(pts, axis=0) for root, pts in clusters.items()}\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Reconstruct lines with snapped endpoints\\n\",\n",
    "    \"    snapped_lines = []\\n\",\n",
    "    \"    for line in gdf.geometry:\\n\",\n",
    "    \"        start_node = centroids[find(tree.query(line.coords[0])[1])]\\n\",\n",
    "    \"        end_node = centroids[find(tree.query(line.coords[-1])[1])]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Keep internal vertices but snap ends\\n\",\n",
    "    \"        new_coords = [start_node] + list(line.coords[1:-1]) + [end_node]\\n\",\n",
    "    \"        if len(new_coords) >= 2 and Point(start_node).distance(Point(end_node)) > 1.0:\\n\",\n",
    "    \"            snapped_lines.append(LineString(new_coords))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 3. Deduplication & Smoothing\\n\",\n",
    "    \"    # Use unary_union to merge overlapping/parallel parts\\n\",\n",
    "    \"    merged = unary_union(snapped_lines)\\n\",\n",
    "    \"    if not isinstance(merged, MultiLineString):\\n\",\n",
    "    \"        merged = MultiLineString([merged])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Simplify and Smooth\\n\",\n",
    "    \"    final_geoms = []\\n\",\n",
    "    \"    for line in merged.geoms:\\n\",\n",
    "    \"        # Douglas-Peucker simplification\\n\",\n",
    "    \"        simple = line.simplify(simplify_tol, preserve_topology=True)\\n\",\n",
    "    \"        # Optional: Apply Chaikin's here if smoother curves are needed\\n\",\n",
    "    \"        final_geoms.append(simple)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 4. Save results\\n\",\n",
    "    \"    final_gdf = gpd.GeoDataFrame(geometry=final_geoms, crs=gdf.crs).to_crs(original_crs)\\n\",\n",
    "    \"    final_gdf.to_file(output_path, driver=\\\"GPKG\\\")\\n\",\n",
    "    \"    print(f\\\"Processed roads saved to {output_path}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Run the process\\n\",\n",
    "    \"post_process_roads(\\n\",\n",
    "    \"    r\\\"outputs\\\\kharita_full_tuned_no_deepmg\\\\kharita_full_tuned_no_deepmg.gpkg\\\",\\n\",\n",
    "    \"    r\\\"outputs\\\\kharita_full_tuned_no_deepmg\\\\kharita_processed.gpkg\\\"\\n\",\n",
    "    \")\\n\"\n",
    "   ],\n",
